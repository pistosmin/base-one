# ====================================================
# 커뮤니티 웹앱 - .gitignore
# Node.js(프론트엔드), Java(백엔드), IDE, OS, Docker 관련 무시 패턴
# ====================================================

# ──────────────────────────────────────────────────────
# Node.js (프론트엔드: apps/web/)
# ──────────────────────────────────────────────────────
node_modules/
dist/
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.tsbuildinfo
coverage/
.vitest/

# ──────────────────────────────────────────────────────
# Java / Gradle (백엔드: apps/api/)
# ──────────────────────────────────────────────────────
build/
.gradle/
*.class
*.jar
*.war
*.ear
*.log
hs_err_pid*
out/

# Gradle 래퍼 (jar만 무시, properties와 스크립트는 커밋)
# !gradle/wrapper/gradle-wrapper.jar  ← 래퍼 jar는 커밋하는 것이 관례
# 여기서는 래퍼를 커밋하기 위해 무시하지 않음

# QueryDSL 생성 파일
**/generated/

# ──────────────────────────────────────────────────────
# IDE (개발 도구)
# ──────────────────────────────────────────────────────
.idea/
*.iml
*.iws
*.ipr
*.swp
*.swo
*~

# VS Code (settings.json은 프로젝트 설정이므로 유지 가능)
# .vscode/는 이미 존재하므로 무시하지 않음

# ──────────────────────────────────────────────────────
# OS (운영 체제 생성 파일)
# ──────────────────────────────────────────────────────
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini

# ──────────────────────────────────────────────────────
# Docker (볼륨 데이터 등)
# ──────────────────────────────────────────────────────
docker-volumes/
pgdata/
redis-data/
minio-data/
grafana-data/

# ──────────────────────────────────────────────────────
# Claude Code (AI 코딩 어시스턴트)
# ──────────────────────────────────────────────────────
# 세션 데이터 (로컬 작업 기록, 커밋 불필요)
.claude/sessions/
.claude/todos.md
# settings.json은 hooks 설정을 포함하므로 커밋
# .claude/skills/gstack/은 팀 공유를 위해 커밋

# ──────────────────────────────────────────────────────
# 기타
# ──────────────────────────────────────────────────────
*.bak
*.tmp
*.temp
.cache/
