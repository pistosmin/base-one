# ====================================================
# 커뮤니티 웹앱 - 환경 변수 설정
# 이 파일을 복사하여 .env 파일을 생성하세요: cp .env.example .env
# 아래 값은 로컬 Docker Compose 개발 환경 기준입니다.
# 프로덕션 배포 시에는 안전한 값으로 반드시 변경하세요!
# ====================================================

# ──────────────────────────────────────────────────────
# PostgreSQL 데이터베이스
# Docker Compose의 postgres 서비스에서 사용
# ──────────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=community
POSTGRES_USER=community
POSTGRES_PASSWORD=community1234

# ──────────────────────────────────────────────────────
# Redis 캐시 & 세션
# JWT 블랙리스트, API 응답 캐시, Rate Limiting에 사용
# ──────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379

# ──────────────────────────────────────────────────────
# MinIO (S3 호환 오브젝트 스토리지)
# 프로필 이미지, 게시글 첨부파일 저장
# ──────────────────────────────────────────────────────
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=community-media

# ──────────────────────────────────────────────────────
# JWT (JSON Web Token) 인증
# SECRET은 프로덕션에서 반드시 강력한 랜덤 문자열로 변경!
# ──────────────────────────────────────────────────────
JWT_SECRET=dev-jwt-secret-key-change-in-production-minimum-32-chars!!
JWT_ACCESS_EXPIRATION=900000
JWT_REFRESH_EXPIRATION=604800000

# ──────────────────────────────────────────────────────
# 애플리케이션 설정
# ──────────────────────────────────────────────────────
APP_PORT=8080
APP_ENV=dev
